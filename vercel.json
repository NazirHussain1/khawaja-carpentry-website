{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "web": {
      "type": "web",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install && npm run build"
    },
    "api": {
      "type": "web",
      "entrypoint": "server/index.js",
      "routePrefix": "/api",
      "framework": "express"
    }
  }
}
