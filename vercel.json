{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "experimentalServices": {
    "api": {
      "type": "web",
      "entrypoint": "server/index.js",
      "routePrefix": "/api",
      "framework": "express"
    },
    "web": {
      "type": "web",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install && npm run build"
    }
  }
}
