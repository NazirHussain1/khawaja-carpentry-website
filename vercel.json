{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "fiasal-fareed-woods": {
      "type": "web",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install && npm run build"
    }
  }
}
